{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "pwa:sync": "rsync -a --delete src/ pwa/app-src/",
    "pwa:dev": "vite --config pwa/vite.config.ts",
    "pwa:build": "vite build --config pwa/vite.config.ts",
    "pwa:preview": "vite preview --config pwa/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "server:dev": "tsx watch server/index.ts",
    "server:start": "tsx server/index.ts",
    "test:app-ready": "npm run typecheck && npm run build",
    "mobile:prep": "npm run typecheck && npm run mobile:sync",
    "mobile:copy": "npm run build && cap copy",
    "mobile:sync": "npm run build && cap sync",
    "mobile:android": "npm run mobile:sync && cap open android",
    "mobile:ios": "npm run mobile:sync && cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "chess.js": "^1.4.0",
    "clsx": "2.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^1.17.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@tailwindcss/vite": "4.1.17",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "tailwindcss": "4.1.17",
    "tsx": "^4.22.4",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vite-plugin-singlefile": "2.3.0"
  }
}
